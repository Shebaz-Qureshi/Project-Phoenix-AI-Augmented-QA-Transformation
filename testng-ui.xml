<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Project Phoenix – UI Tests Only -->
<suite name="Project Phoenix – UI Suite" verbose="1" thread-count="2">

    <parameter name="browser"  value="chrome"/>
    <parameter name="headless" value="false"/>
    <parameter name="baseUrl"  value="https://the-internet.herokuapp.com"/>

    <listeners>
        <listener class-name="com.phoenix.listeners.TestListener"/>
        <listener class-name="com.phoenix.listeners.RetryListener"/>
    </listeners>

    <test name="UI Tests – Login">
        <groups>
            <run>
                <include name="ui"/>
            </run>
        </groups>
        <classes>
            <class name="com.phoenix.ui.LoginTest"/>
        </classes>
    </test>

    <test name="UI Tests – Upload">
        <groups>
            <run>
                <include name="ui"/>
            </run>
        </groups>
        <classes>
            <class name="com.phoenix.ui.UploadTest"/>
        </classes>
    </test>

</suite>
